# World Cup API environment.
# Generate hashes with:  printf '%s' 'your-passcode' | shasum -a 256
# Generate token secret with:  openssl rand -hex 32

# sha256 hex of the shared MEMBER passcode (gates betting writes)
WC_MEMBER_PASSCODE_HASH=<sha256 hex of member passcode>

# sha256 hex of the ADMIN passcode (gates POST /admin/result)
WC_ADMIN_PASSCODE_HASH=<sha256 hex of admin passcode>

# HMAC secret used to sign member tokens (random, keep private)
WC_TOKEN_SECRET=<random hex, e.g. openssl rand -hex 32>

# Absolute path to the SQLite database file
WC_DB=/var/www/sigmlab/wc-api/wc.db
